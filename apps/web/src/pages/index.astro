---
import { PUBLIC_CDN_URL } from "astro:env/server";
import type { InferResponseType } from "hono/client";
import DatePicker from "../components/DatePicker";
import UrlRow from "../components/UrlRow";
import Layout from "../layouts/Layout.astro";
import { getServerClient } from "../libs/api-client";

const env = Astro.locals.runtime.env;
const client = getServerClient(env);
const cdn = PUBLIC_CDN_URL;

const url = new URL(Astro.request.url);
const deviceParam = url.searchParams.get("device");
const dateParam = url.searchParams.get("date");
const langParams = url.searchParams.getAll("lang");

const currentDevice = deviceParam === "mobile" ? "mobile" : "desktop";
const today = new Intl.DateTimeFormat("en-CA", {
  timeZone: "Europe/Warsaw",
}).format(new Date());
const currentDate = dateParam || today;

type UrlData = InferResponseType<typeof client.urls.$get>[0];
let urls: UrlData[] = [];
let languages: string[] = [];
let availableDates: string[] = [];
let error: string | null = null;

try {
  const [urlsRes, langsRes, datesRes] = await Promise.all([
    client.urls.$get(),
    client.languages.$get(),
    client["available-dates"].$get({ query: {} }),
  ]);

  if (!urlsRes.ok || !langsRes.ok || !datesRes.ok) {
    error = "Failed to fetch initial data from API.";
  } else {
    urls = await urlsRes.json();
    languages = await langsRes.json();
    availableDates = await datesRes.json();

    urls.sort((a, b) => a.url.localeCompare(b.url));
  }
} catch (e) {
  console.error(e);
  error = "Proxy failed to fetch history data.";
}

const filteredUrls =
  langParams.length > 0
    ? urls.filter((u) => langParams.includes(u.language))
    : urls;

const languageNames = new Intl.DisplayNames(["en"], { type: "language" });

const buildLangToggleUrl = (lang: string) => {
  const newUrl = new URL(Astro.request.url);
  const currentLangs = newUrl.searchParams.getAll("lang");

  newUrl.searchParams.delete("lang");

  if (currentLangs.includes(lang)) {
    currentLangs
      .filter((l) => l !== lang)
      .forEach((l) => {
        newUrl.searchParams.append("lang", l);
      });
  } else {
    currentLangs.forEach((l) => {
      newUrl.searchParams.append("lang", l);
    });
    newUrl.searchParams.append("lang", lang);
  }

  return newUrl.toString();
};

const clearLangsUrl = () => {
  const newUrl = new URL(Astro.request.url);
  newUrl.searchParams.delete("lang");
  return newUrl.toString();
};
---

<Layout title={`History - ${currentDate}`}>
  <div class=" space-y-8 pb-20">
    {
      error ? (
        <div class="flex flex-col gap-1 p-5 bg-red-50 border-l-4 border-red-500 rounded-r-xl text-red-800 shadow-sm">
          <h2 class="text-sm font-bold uppercase tracking-wide text-red-600">
            Notice
          </h2>
          <p class="text-base">{error}</p>
        </div>
      ) : (
        <>
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 bg-white p-2 rounded-2xl shadow-sm border border-slate-200">
            {languages.length > 0 && (
              <div class="flex flex-col sm:flex-row sm:items-center gap-3 w-full md:w-auto px-2 py-1">
                <span class="text-xs font-semibold text-slate-400 uppercase tracking-widest shrink-0">
                  Language
                </span>

                <div class="flex flex-wrap items-center gap-2">
                  <a
                    href={clearLangsUrl()}
                    class={`inline-flex items-center justify-center px-4 py-1.5 text-sm font-medium rounded-full transition-all duration-200 ${
                      langParams.length === 0
                        ? "bg-slate-800 text-white shadow-md"
                        : "bg-slate-100 text-slate-600 hover:bg-slate-200"
                    }`}
                  >
                    All
                  </a>

                  <div class="h-5 w-px bg-slate-200 hidden sm:block mx-1" />

                  {languages.map((lang) => {
                    const isSelected = langParams.includes(lang);

                    return (
                      <a
                        href={buildLangToggleUrl(lang)}
                        class={`inline-flex items-center justify-center px-4 py-1.5 text-sm font-medium rounded-full border transition-all duration-200 ${
                          isSelected
                            ? "bg-blue-50 border-blue-200 text-blue-700 shadow-sm ring-1 ring-blue-500"
                            : "bg-white border-slate-200 text-slate-600 hover:bg-slate-50 hover:border-slate-300"
                        }`}
                      >
                        {isSelected && (
                          <svg
                            class="w-3.5 h-3.5 mr-1.5 text-blue-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            aria-hidden="true"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="3"
                              d="M5 13l4 4L19 7"
                            />
                          </svg>
                        )}
                        {languageNames.of(lang) || lang}
                      </a>
                    );
                  })}
                </div>
              </div>
            )}

            <div class="shrink-0 px-2 pb-2 md:pb-0 relative z-10 w-full md:w-auto flex justify-end">
              <DatePicker
                client:load
                initialDate={currentDate}
                availableDates={availableDates}
              />
            </div>
          </div>

          <div class="space-y-4">
            {filteredUrls.length === 0 ? (
              <div class="flex flex-col items-center justify-center py-16 px-4 text-center rounded-2xl border-2 border-dashed border-slate-200 bg-slate-50/50">
                <div class="rounded-full bg-slate-100 p-3 mb-3">
                  <svg
                    class="w-6 h-6 text-slate-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <title>No URLs Found</title>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                    />
                  </svg>
                </div>
                <h3 class="text-sm font-medium text-slate-900">
                  No URLs found
                </h3>
                <p class="text-sm text-slate-500 mt-1">
                  Try adjusting your language filters or selecting a different
                  date.
                </p>
              </div>
            ) : (
              <div class="grid gap-4">
                {filteredUrls.map((u) => (
                  <UrlRow
                    client:idle
                    url={u.url}
                    initialDevice={currentDevice}
                    date={currentDate}
                    cdn={cdn}
                  />
                ))}
              </div>
            )}
          </div>
        </>
      )
    }
  </div>
</Layout>
