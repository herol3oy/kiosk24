---
import { PUBLIC_CDN_URL } from "astro:env/server";
import type { InferResponseType } from "hono/client";
import LatestGrid from "../../components/LatestGrid";
import Layout from "../../layouts/Layout.astro";
import { getServerClient } from "../../libs/api-client";

const env = Astro.locals.runtime.env;
const client = getServerClient(env);
const cdn = PUBLIC_CDN_URL;

const deviceParam = Astro.url.searchParams.get("device");
const isDesktop = deviceParam !== "mobile";

type LatestScreenshotsData = InferResponseType<typeof client.latest.$get>;

let data: LatestScreenshotsData | null = null;
let error: string | null = null;

try {
  const res = await client.latest.$get({
    query: {
      device: isDesktop ? "desktop" : "mobile",
    },
  });

  if (!res.ok) {
    error = `Failed to fetch latest screenshots: ${res.status}`;
  } else {
    data = await res.json();
    if (data && data.length === 0) {
      error = "No latest screenshots found.";
    }
  }
} catch (e) {
  console.error(e);
  error = "Proxy failed to fetch latest data";
}
---

<Layout title="Latest Screenshots">
  <div class="max-w-7xl mx-auto mb-8">
    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">
      Latest Screenshots
    </h1>
  </div>

  <LatestGrid 
    client:load 
    data={data} 
    error={error} 
    cdn={cdn} 
    isDesktop={isDesktop} 
  />
</Layout>