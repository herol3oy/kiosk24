---
import { PUBLIC_CDN_URL } from "astro:env/server";
import type { InferResponseType } from "hono/client";
import Latest from "../../components/Latest";
import Layout from "../../layouts/Layout.astro";
import { getServerClient } from "../../libs/api-client";

const env = Astro.locals.runtime.env;
const client = getServerClient(env);
const cdn = PUBLIC_CDN_URL;

const deviceParam = Astro.url.searchParams.get("device");
const isDesktop = deviceParam === "desktop";
const langParams = Astro.url.searchParams.getAll("lang");

const [languagesRes, latestRes] = await Promise.all([
  client.languages.$get(),
  client.latest.$get({
    query: {
      device: isDesktop ? "desktop" : "mobile",
    },
  }),
]);

let languages: string[] = [];
if (languagesRes.ok) {
  languages = await languagesRes.json();
}

type LatestScreenshotsData = InferResponseType<typeof client.latest.$get>;

let data: LatestScreenshotsData | null = null;
let error: string | null = null;

if (!latestRes.ok) {
  error = `Failed to fetch latest screenshots: ${latestRes.status}`;
} else {
  data = await latestRes.json();
  if (data && data.length === 0) {
    error = "No latest screenshots found.";
  }
}
---

<Layout title="News in the Last Hour">
  <div class="mb-8">
    <Latest
      client:load
      initialData={data}
      initialError={error}
      cdn={cdn}
      initialDevice={isDesktop ? "desktop" : "mobile"}
      languages={languages}
      initialLangParams={langParams}
    />
  </div>
</Layout>
