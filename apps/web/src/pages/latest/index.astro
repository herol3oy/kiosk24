---
import { PUBLIC_CDN_URL } from "astro:env/server";
import type { InferResponseType } from "hono/client";
import Layout from "../../layouts/Layout.astro";
import { getServerClient } from "../../libs/api-client";

const env = Astro.locals.runtime.env;

const client = getServerClient(env);

const cdn = PUBLIC_CDN_URL;

const deviceParam = Astro.url.searchParams.get("device");
const isDesktop = deviceParam !== "mobile";
const thumbWidth = isDesktop ? 600 : 400;
const gridClass = isDesktop
  ? "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 2xl:grid-cols-5"
  : "grid-cols-2 md:grid-cols-3 lg:grid-cols-5";
const aspectClass = isDesktop ? "aspect-16/10" : "aspect-9/16";

type LatestScreenshotsData = InferResponseType<typeof client.latest.$get>;

let data: LatestScreenshotsData | null = null;
let error: string | null = null;

try {
  const res = await client.latest.$get({
    query: {
      device: isDesktop ? "desktop" : "mobile",
    },
  });

  if (!res.ok) {
    error = `Failed to fetch latest screenshots: ${res.status}`;
  } else {
    data = await res.json();
    if (data && data.length === 0) {
      error = "No latest screenshots found.";
    }
  }
} catch (e) {
  console.error(e);
  error = "Proxy failed to fetch latest data";
}

const buildImageUrls = (cdnUrl: string, key: string | null, width: number) => ({
  full: cdnUrl.includes("localhost")
    ? `${cdnUrl}/${key}`
    : `${cdnUrl}/cdn-cgi/image/width=1600,quality=60,format=auto/${key}`,
  thumb: cdnUrl.includes("localhost")
    ? `${cdnUrl}/${key}`
    : `${cdnUrl}/cdn-cgi/image/width=${width},quality=50,fit=cover,format=auto/${key}`,
});

const getHostname = (url: string) => {
  try {
    return new URL(url).hostname.replace("www.", "");
  } catch {
    return url;
  }
};
---

<Layout title="Latest Screenshots">
  <div class="max-w-7xl mx-auto mb-8">
    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">
      Latest Screenshots
    </h1>
  </div>

  {
    error ? (
      <div class="flex flex-col items-center justify-center py-20 px-4 text-center rounded-2xl border-2 border-dashed border-red-200 bg-red-50 max-w-7xl mx-auto">
        <div class="rounded-full bg-red-100 p-3 mb-3 text-red-500">
          <svg
            class="w-8 h-8"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <title>Error</title>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
            />
          </svg>
        </div>
        <p class="text-base text-red-800 font-medium">{error}</p>
      </div>
    ) : data ? (
      <div class={`grid gap-6 max-w-7xl mx-auto ${gridClass}`}>
        {data.map((item) => {
          const hostname = getHostname(item.url);
          const favicon = `https://www.google.com/s2/favicons?domain=${item.url}&sz=64`;
          const isOk = item.job_status === "ok";
          const images = buildImageUrls(cdn, item.r2_key, thumbWidth);
          const linkHref = isOk ? images.full : item.url;

          return (
            <article class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden hover:shadow-lg transition-all duration-300 flex flex-col group/card">
              <div class="px-3 py-2.5 border-b border-slate-100 bg-slate-50/80 flex items-center justify-between">
                <div class="flex items-center gap-2.5 overflow-hidden">
                  <div class="p-1 bg-white rounded-md shadow-sm border border-slate-100 shrink-0">
                    <img
                      src={favicon}
                      alt=""
                      loading="lazy"
                      class="w-3.5 h-3.5"
                    />
                  </div>
                  <h3
                    class="text-xs font-bold text-slate-700 truncate"
                    title={item.url}
                  >
                    {hostname}
                  </h3>
                </div>
                <span class="shrink-0 px-2 py-0.5 rounded-full bg-slate-200/50 text-slate-600 font-semibold text-[10px] tracking-wider uppercase border border-slate-200/50">
                  {item.language}
                </span>
              </div>

              <div
                class={`relative bg-slate-100 border-b border-slate-100 group ${aspectClass}`}
              >
                {!isOk ? (
                  <div class="absolute inset-0 flex flex-col items-center justify-center text-slate-400 bg-slate-50">
                    <svg
                      class="w-8 h-8 mb-2 text-red-400"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <title>Error</title>
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                    <span class="text-xs font-bold uppercase tracking-wider text-slate-500">
                      Failed
                    </span>
                  </div>
                ) : (
                  <img
                    src={images.thumb}
                    srcset={
                      isDesktop
                        ? `${images.thumb} 1x, ${images.full} 2x`
                        : undefined
                    }
                    alt={`Screenshot of ${hostname}`}
                    loading="lazy"
                    decoding="async"
                    class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-700 group-hover/card:scale-105"
                  />
                )}
                <div class="absolute inset-0 bg-black/0 group-hover/card:bg-black/5 transition-colors duration-300 pointer-events-none" />
                <a
                  href={linkHref}
                  target="_blank"
                  rel="noreferrer"
                  class="absolute inset-0 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 z-10"
                  aria-label={`View ${isOk ? "screenshot" : "site"} of ${hostname} (opens in new tab)`}
                >
                  <span class="sr-only">
                    View {isOk ? "screenshot" : "site"} of {hostname}
                  </span>
                </a>
              </div>

              <div class="px-4 py-2.5 bg-white flex justify-between items-center text-[11px] text-slate-400 font-medium">
                <time
                  datetime={item.created_at}
                  class="flex items-center gap-1.5"
                >
                  <svg
                    class="w-3.5 h-3.5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <title>Created At</title>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                    />
                  </svg>
                  {new Date(item.created_at).toLocaleString([], {
                    month: "short",
                    day: "numeric",
                    hour: "2-digit",
                    minute: "2-digit",
                  })}
                </time>
              </div>
            </article>
          );
        })}
      </div>
    ) : null
  }
</Layout>
