---
import type { InferResponseType } from "hono/client";
import Layout from "../../layouts/Layout.astro";

import { getServerClient } from "../../libs/api-client";

const env = Astro.locals.runtime.env;

const client = getServerClient(env);

type StatusData = InferResponseType<typeof client.status.$get>[0];

let data: StatusData[] | null = null;
let error: string | null = null;

try {
  const res = await client.status.$get();

  if (!res.ok) {
    error = `Failed to fetch status: ${res.status}`;
  } else {
    data = await res.json();
    if (data && data.length === 0) {
      error = "No run metadata found";
    }
  }
} catch (e) {
  console.error(e);
  error = "Proxy failed to fetch status data";
}

const formatDate = (isoString: string) => {
  return new Date(isoString).toLocaleString();
};

const getDuration = (run: StatusData) => {
  return (
    (new Date(run.job_completion_timestamp).getTime() -
      new Date(run.job_start_timestamp).getTime()) /
    1000
  );
};

const getSuccessRate = (run: StatusData) => {
  return Math.round((run.completed_screenshots / run.total_screenshots) * 100);
};
---

<Layout title="System Status">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900 tracking-tight">
      Run History
    </h1>
  </div>

  {
    error ? (
      <div class="flex flex-col gap-1 p-5 bg-red-50 border-l-4 border-red-500 rounded-r-xl text-red-800 shadow-sm">
        <h2 class="text-sm font-bold uppercase tracking-wide text-red-600">
          Notice
        </h2>
        <p class="text-base">{error}</p>
      </div>
    ) : data ? (
      <div class="space-y-4">
        {data.map((run, index) => (
          <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition-shadow duration-200">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-2 flex-1">
                <span class="inline-flex items-center px-2.5 py-1 rounded-md bg-slate-100 text-slate-700 text-xs font-bold tracking-wide">
                  Run #{data.length - index}
                </span>

                <span class="text-slate-300 hidden sm:inline">|</span>

                <span class="text-sm font-medium text-slate-600">
                  {formatDate(run.job_start_timestamp)}
                </span>

                <span class="text-slate-300 hidden sm:inline">|</span>

                <span class="text-sm text-slate-500">
                  <span class="font-medium text-slate-700">
                    {getDuration(run).toFixed(1)}s
                  </span>{" "}
                  duration
                </span>

                <span class="text-slate-300 hidden sm:inline">|</span>

                <span class="text-sm text-slate-500">
                  <span class="font-medium text-slate-700">
                    {run.total_urls}
                  </span>{" "}
                  URLs
                </span>
              </div>

              <div class="flex items-center gap-4 text-sm bg-slate-50 px-3 py-1.5 rounded-lg border border-slate-100">
                <span class="text-slate-600" title="Total Screenshots">
                  {run.total_screenshots} total
                </span>

                <span
                  class="text-emerald-600 font-semibold flex items-center gap-1"
                  title="Successful"
                >
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <title>Successful Screenshots</title>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  {run.completed_screenshots}
                </span>

                <span
                  class="text-red-500 font-semibold flex items-center gap-1"
                  title="Failed"
                >
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <title>Failed Screenshots</title>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M6 18L18 6M6 6l12 12"
                    />
                  </svg>
                  {run.failed_screenshots}
                </span>

                <span class="font-bold text-slate-900 ml-1">
                  {getSuccessRate(run)}%
                </span>
              </div>
            </div>

            <div class="mt-4 w-full bg-slate-100 rounded-full h-2 overflow-hidden border border-slate-200/50">
              <div
                class="bg-emerald-500 h-full transition-all duration-1000 ease-out"
                style={`width: ${getSuccessRate(run)}%`}
              />
            </div>
          </div>
        ))}
      </div>
    ) : null
  }
</Layout>
