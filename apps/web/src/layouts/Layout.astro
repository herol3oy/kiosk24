---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import TopBar from "../components/TopBar";

interface Props {
    title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const currentUrl = Astro.url.href;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <ClientRouter />
    </head>
    <body
        class="bg-slate-50 text-slate-900 min-h-screen flex flex-col antialiased selection:bg-blue-100 selection:text-blue-900"
    >
        <TopBar currentPath={currentPath} currentUrl={currentUrl} client:load />

        <main class="flex-1 w-full mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
            <slot />
        </main>
    </body>
</html>
